# ============================================================
# GymFlow AI — Production Environment Variables
# ============================================================
# Vercel Dashboard → gymflow-ai → Settings → Environment Variables
# "Import .env File" button se upload karo
# Pehle sab "your-xxx" values apni real keys se replace karo
# ============================================================


# ── 1. SUPABASE (Database + Auth + Realtime) ─────────────────
# Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-service-role-key


# ── 2. OPENAI (AI Chatbot) ────────────────────────────────────
# platform.openai.com → API Keys
OPENAI_API_KEY=sk-proj-your-openai-key-here
OPENAI_MODEL=gpt-4o


# ── 3. WHATSAPP CLOUD API (Meta) ─────────────────────────────
# developers.facebook.com → App → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=EAAyour-access-token-here
WHATSAPP_VERIFY_TOKEN=gymflow_verify_secret123
WHATSAPP_BUSINESS_ACCOUNT_ID=your-waba-id
